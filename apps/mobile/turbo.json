{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": []
    },
    "ios": {
      "cache": false,
      "persistent": true
    },
    "android": {
      "cache": false,
      "persistent": true
    },
    "web": {
      "cache": false,
      "persistent": true
    },
    "build:eas": {
      "cache": false
    },
    "expo:upgrade": {
      "cache": false
    },
    "expo:fix": {
      "cache": false
    }
  }
}
