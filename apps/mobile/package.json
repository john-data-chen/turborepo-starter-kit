{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo start --android --clear",
    "build": "tsc --noEmit",
    "build:eas": "eas build",
    "dev": "expo start --ios --clear",
    "expo:fix": "npx expo install --fix",
    "expo:upgrade": "npx expo install expo@latest && npx expo install --fix",
    "format": "cd ../.. && oxfmt --no-error-on-unmatched-pattern --config .oxfmtrc.json apps/mobile",
    "lint": "npx oxlint --config ../../.oxlintrc.json --fix",
    "prepare": "if [ \"$NODE_ENV\" != \"production\" ]; then husky; fi"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-native-segmented-control/segmented-control": "^2.5.7",
    "@react-navigation/native": "^7.1.8",
    "@repo/i18n": "workspace:*",
    "@repo/store": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-localization": "^17.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.8.11",
    "nativewind": "5.0.0-preview.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-css": "^3.0.1",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/i18next": "^13.0.0",
    "@types/react": "~19.1.0",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.2"
  }
}