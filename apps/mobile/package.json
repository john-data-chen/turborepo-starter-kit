{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo start --android",
    "build": "tsgo --noEmit",
    "build:eas": "eas build",
    "dev": "expo start --ios",
    "expo:fix": "npx expo install --fix",
    "expo:upgrade": "npx expo install expo@latest && npx expo install --fix",
    "format": "cd ../.. && oxfmt --no-error-on-unmatched-pattern --config .oxfmtrc.json apps/mobile",
    "lint": "npx oxlint --config ../../.oxlintrc.json --fix",
    "prepare": "if [ \"$NODE_ENV\" != \"production\" ]; then husky; fi",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-segmented-control/segmented-control": "^2.5.7",
    "@react-navigation/native": "^7.1.28",
    "@repo/i18n": "workspace:*",
    "@repo/store": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "expo": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.9",
    "expo-localization": "^55.0.9",
    "expo-router": "~55.0.8",
    "expo-secure-store": "^55.0.9",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.10",
    "i18next": "^25.8.13",
    "nativewind": "5.0.0-preview.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.83.2",
    "react-native-css": "^3.0.4",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.2",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "catalog:",
    "@testing-library/react-native": "^13.3.3",
    "@types/i18next": "^13.0.0",
    "@types/react": "~19.2.14",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "happy-dom": "^20.7.0",
    "tailwindcss": "catalog:",
    "vitest": "catalog:"
  }
