{
  "name": "@repo/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo start --android",
    "build:eas": "eas build",
    "check-types": "tsgo --noEmit",
    "dev": "expo start --ios",
    "expo:fix": "npx expo install --fix",
    "expo:upgrade": "npx expo install expo@latest && npx expo install --fix",
    "format": "cd ../.. && oxfmt --no-error-on-unmatched-pattern --config .oxfmtrc.json apps/mobile",
    "lint": "npx oxlint --config ../../.oxlintrc.json --fix",
    "prepare": "if [ \"$NODE_ENV\" != \"production\" ]; then husky; fi",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.3",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-segmented-control/segmented-control": "^2.5.7",
    "@react-navigation/native": "^7.3.7",
    "@repo/i18n": "workspace:*",
    "@repo/store": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-localization": "^57.0.0",
    "expo-router": "~57.0.4",
    "expo-secure-store": "^57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "i18next": "^26.3.4",
    "nativewind": "5.0.0-preview.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-css": "^3.0.7",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.10.0",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "~19.2.17",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "happy-dom": "^20.10.6",
    "tailwindcss": "catalog:",
    "vitest": "catalog:"
  }
}
