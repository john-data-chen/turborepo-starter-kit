{
  "name": "@repo/store",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsgo --noEmit",
    "format": "cd ../.. && oxfmt --no-error-on-unmatched-pattern --config .oxfmtrc.json packages/store",
    "lint": "npx oxlint --config ../../.oxlintrc.json --fix",
    "prepare": "if [ \"$NODE_ENV\" != \"production\" ]; then husky; fi"
  },
  "dependencies": {
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "global-tsconfig": "workspace:*"
  }
}